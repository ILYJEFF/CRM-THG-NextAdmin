generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CrmContact {
  id                String     @id @default(cuid())
  companyName       String?
  contactName       String
  email             String
  phone             String
  city              String
  industry          String?
  openPositions     String?
  payBand           String?
  message           String
  jobDescriptionUrl String?
  status            String     @default("new")
  notes             String?
  clientId          String?    @unique
  client            CrmClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@map("crm_contacts")
}

model CrmClient {
  id              String               @id @default(cuid())
  companyName     String?
  contactName     String
  email           String
  phone           String
  city            String
  industry        String?
  internalNotes   String?
  convertedLead   CrmContact?
  jobOrders       CrmJobOrder[]
  contracts       CrmClientContract[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@map("crm_clients")
}

model CrmJobOrder {
  id           String    @id @default(cuid())
  clientId     String
  client       CrmClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title        String
  roleSummary  String?
  status       String    @default("open")
  priority     String    @default("normal")
  notes        String?

  /// Public opening copy (synced to thehammittgroup.com /openings)
  publicDescription    String?  @db.Text
  publicLocation       String?
  publicEmploymentType String?  @default("FULL_TIME")
  publicCompanyName    String?
  responsibilities     String?  @db.Text
  requirements       String?  @db.Text
  salaryMin          Int?
  salaryMax          Int?
  salaryPeriod       String?

  careerPostingId   String?
  careerSlug        String?
  careerPublishedAt DateTime?
  careerLastSyncAt  DateTime?
  careerLastError   String?

  submissions CrmSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("crm_job_orders")
}

model CrmSubmission {
  id          String       @id @default(cuid())
  candidateId String
  candidate   CrmCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOrderId  String
  jobOrder    CrmJobOrder  @relation(fields: [jobOrderId], references: [id], onDelete: Cascade)
  stage       String       @default("triage")
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([candidateId, jobOrderId])
  @@index([jobOrderId])
  @@index([candidateId])
  @@map("crm_submissions")
}

model CrmClientContract {
  id        String    @id @default(cuid())
  clientId  String
  client    CrmClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  label     String?
  fileUrl   String
  fileName  String
  mimeType  String?
  createdAt DateTime  @default(now())

  @@index([clientId])
  @@map("crm_client_contracts")
}

model CrmCandidate {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  phone           String
  currentLocation String
  desiredLocation String
  industry        String
  positionType    String
  resumeUrl       String?
  coverLetter     String?
  status          String   @default("new")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  submissions CrmSubmission[]

  @@map("crm_candidates")
}

/// Touch history: calls, emails, meetings, notes on a lead, client, or candidate
model CrmActivity {
  id           String   @id @default(cuid())
  entityType   String
  entityId     String
  activityType String   @default("note")
  body         String   @db.Text
  actorEmail   String?
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("crm_activities")
}
