generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CrmContact {
  id                String     @id @default(cuid())
  companyName       String?
  contactName       String
  email             String
  phone             String
  city              String
  industry          String?
  openPositions     String?
  payBand           String?
  message           String
  jobDescriptionUrl String?
  status            String     @default("new")
  notes             String?
  clientId          String?    @unique
  client            CrmClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@map("crm_contacts")
}

model CrmClient {
  id              String               @id @default(cuid())
  companyName     String?
  contactName     String
  email           String
  phone           String
  city            String
  industry        String?
  internalNotes   String?
  /// e.g. retained, container, project, hourly
  engagementType  String?
  feeSummary      String?              @db.Text
  warrantySummary String?              @db.Text
  commercialNotes String?              @db.Text
  agreementRenewalAt DateTime?
  nextReviewAt    DateTime?
  lastReviewAt    DateTime?
  convertedLead   CrmContact?
  jobOrders       CrmJobOrder[]
  contracts       CrmClientContract[]
  accountTasks    CrmAccountTask[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([nextReviewAt])
  @@map("crm_clients")
}

/// Editable desk reference (fees, warranty, ops). Rendered on /admin/playbook.
model CrmPlaybookSection {
  id        String   @id @default(cuid())
  slug      String   @unique
  eyebrow   String   @default("")
  title     String
  sortOrder Int      @default(0)
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("crm_playbook_sections")
}

/// Per-client maintenance and follow-up tasks (not the same as CrmActivity).
model CrmAccountTask {
  id          String    @id @default(cuid())
  clientId    String
  client      CrmClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?   @db.Text
  dueAt       DateTime?
  completedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
  @@index([clientId, completedAt])
  @@map("crm_account_tasks")
}

model CrmJobOrder {
  id           String    @id @default(cuid())
  clientId     String
  client       CrmClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title        String
  roleSummary  String?
  status       String    @default("open")
  priority     String    @default("normal")
  notes        String?

  /// Public opening copy (synced to thehammittgroup.com /openings)
  publicDescription    String?  @db.Text
  publicLocation       String?
  publicEmploymentType String?  @default("FULL_TIME")
  publicCompanyName    String?
  responsibilities     String?  @db.Text
  requirements       String?  @db.Text
  salaryMin          Int?
  salaryMax          Int?
  salaryPeriod       String?

  careerPostingId   String?
  careerSlug        String?
  careerPublishedAt DateTime?
  careerLastSyncAt  DateTime?
  careerLastError   String?

  submissions CrmSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("crm_job_orders")
}

model CrmSubmission {
  id          String       @id @default(cuid())
  candidateId String
  candidate   CrmCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOrderId  String
  jobOrder    CrmJobOrder  @relation(fields: [jobOrderId], references: [id], onDelete: Cascade)
  stage       String       @default("triage")
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([candidateId, jobOrderId])
  @@index([jobOrderId])
  @@index([candidateId])
  @@map("crm_submissions")
}

model CrmClientContract {
  id        String    @id @default(cuid())
  clientId  String
  client    CrmClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  label     String?
  fileUrl   String
  fileName  String
  mimeType  String?
  createdAt DateTime  @default(now())

  @@index([clientId])
  @@map("crm_client_contracts")
}

model CrmCandidate {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  phone           String
  currentLocation String
  desiredLocation String
  industry        String
  positionType    String
  resumeUrl       String?
  coverLetter     String?
  status          String   @default("new")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  submissions CrmSubmission[]

  @@map("crm_candidates")
}

/// Touch history: calls, emails, meetings, notes on a lead, client, or candidate
model CrmActivity {
  id           String   @id @default(cuid())
  entityType   String
  entityId     String
  activityType String   @default("note")
  body         String   @db.Text
  actorEmail   String?
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("crm_activities")
}

/// Marketing-site email templates (submitter thank-yous, welcome, etc.). The
/// public site loads these via /api/integrations/email-template with a shared secret.
model CrmMarketingEmailTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  subject     String
  htmlBody    String   @db.Text
  description String?
  variables   String?
  category    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([isActive])
  @@map("crm_marketing_email_templates")
}

model CrmNurtureCampaign {
  id          String                     @id @default(cuid())
  name        String
  description String?                    @db.Text
  isActive    Boolean                    @default(true)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  members     CrmNurtureCampaignMember[]

  @@index([isActive])
  @@map("crm_nurture_campaigns")
}

model CrmNurtureCampaignMember {
  id          String              @id @default(cuid())
  campaignId  String
  campaign    CrmNurtureCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  email       String
  firstName   String?
  lastName    String?
  notes       String?             @db.Text
  source      String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([campaignId, email])
  @@index([email])
  @@index([campaignId])
  @@map("crm_nurture_campaign_members")
}
