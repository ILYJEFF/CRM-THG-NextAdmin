# Supabase Postgres (same DB the marketing site syncs into via Supabase API)
# On Vercel, either set DATABASE_URL, or rely on POSTGRES_PRISMA_URL from the integration.
# Use the Supabase *pooler* URL for runtime (port 6543, pgbouncer=true). Direct 5432 is for migrations only.
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# POSTGRES_PRISMA_URL="postgres://..."

# First-time DB: run prisma/sql/init_crm_tables.sql in Supabase SQL Editor, or locally:
#   npx prisma db push
# If db push hangs on the pooler, use the direct (5432) connection string as DATABASE_URL for that command only.
# Candidate recruiter notes column (if DB predates it): prisma/sql/add_candidate_notes.sql
#
# After deploying CRM code with clients / job orders: apply schema to production or you get P2022 (missing clientId).
#   npx prisma db push   (with direct 5432 URL), or run prisma/sql/add_clients_module.sql in Supabase SQL Editor.
#
# "connection failure during authentication": wrong or rotated DB password in Vercel env, or using session pooler with IPv4-only host; fix credentials / use transaction pooler URL from Supabase.
# Production app adds connection_limit=1 automatically unless PRISMA_SERVERLESS_POOL_OFF=1.

# Supabase Auth (browser + middleware)
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Server-only (scripts / optional server jobs). Never NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=""

# Used for absolute redirects after sign out (production CRM URL)
NEXT_PUBLIC_SITE_URL="https://crm.thehammittgroup.com"

# After deploy, open https://your-crm-domain/api/health — both checks must be true

# Main marketing site (sidebar link)
NEXT_PUBLIC_MARKETING_URL="https://www.thehammittgroup.com"

# Shared with marketing site (Vercel): server-to-server ingest for contact / resume forms.
# Use a long random string (16+ chars). Same value as THG_FORM_INTEGRATION_SECRET on the marketing project.
THG_FORM_INTEGRATION_SECRET=""
